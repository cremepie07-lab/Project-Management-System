generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships     WorkspaceMember[]
  cardAssignments CardMember[]
  activities      Activity[]
  timeEntries     TimeEntry[]
  completedCards  Card[]       @relation("CompletedBy")
  notifications   Notification[]

  @@map("users")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members WorkspaceMember[]
  boards  Board[]

  @@map("workspaces")
}

model WorkspaceMember {
  id   String        @id @default(cuid())
  role WorkspaceRole @default(MEMBER)

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model Board {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  lists  List[]
  labels Label[]

  @@index([workspaceId])
  @@map("boards")
}

model List {
  id        String   @id @default(cuid())
  title     String
  order     Float                  // ← Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cards Card[]

  @@index([boardId])
  @@map("lists")
}

model Card {
  id          String    @id @default(cuid())
  title       String
  description String?
  order       Float                // ← Float
  color       String?
  dueDate     DateTime?

  listId String
  list   List   @relation(fields: [listId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cardLabels  CardLabel[]
  cardMembers CardMember[]
  checklists  Checklist[]
  activities  Activity[]
  timeEntries TimeEntry[]
  totalTimeSpent Int @default(0) @map("total_time_spent")

  // Recurrence
  isRecurring        Boolean   @default(false)
  recurrenceInterval String?   // "DAILY", "WEEKLY", "MONTHLY"
  nextRecurrence     DateTime?

  // Completion
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  completedBy  String?
  completedByUser User?   @relation("CompletedBy", fields: [completedBy], references: [id], onDelete: SetNull)

  // Dependencies
  dependencies       CardDependency[] @relation("BlockedCard")
  blockedCards       CardDependency[] @relation("BlockerCard")

  @@index([listId])
  @@map("cards")
}

model CardDependency {
  id          String   @id @default(cuid())
  cardId      String
  card        Card     @relation("BlockedCard", fields: [cardId], references: [id], onDelete: Cascade)
  dependsOnId String
  dependsOn   Card     @relation("BlockerCard", fields: [dependsOnId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([cardId, dependsOnId])
  @@map("card_dependencies")
}

model Checklist {
  id    String @id @default(cuid())
  title String
  order Float

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)

  items ChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cardId])
  @@map("checklists")
}

model ChecklistItem {
  id     String  @id @default(cuid())
  title  String
  isDone Boolean @default(false)
  order  Float

  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([checklistId])
  @@map("checklist_items")
}

// type: "COMMENT" (bình luận của người dùng) | "SYSTEM" (tự động ghi lại thao tác)
model Activity {
  id      String @id @default(cuid())
  type    String
  message String

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([cardId])
  @@map("activities")
}

model TimeEntry {
  id        String    @id @default(cuid())
  startedAt DateTime
  endedAt   DateTime?
  note      String?

  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([cardId])
  @@map("time_entries")
}

model Label {
  id    String @id @default(cuid())
  name  String
  color String

  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  cardLabels CardLabel[]

  @@map("labels")
}

model CardLabel {
  cardId  String
  card    Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  labelId String
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@map("card_labels")
}

model CardMember {
  cardId String
  card   Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cardId, userId])
  @@map("card_members")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  linkUrl   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}